{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VINTRACK Contract Registry",
  "description": "Canonical semantic ownership and contract governance.",
  "type": "object",
  "required": ["contracts"],
  "properties": {
    "contracts": {
      "type": "object",
      "patternProperties": {
        "^[A-Za-z][A-Za-z0-9]*$": {
          "type": "object",
          "required": ["owner", "location", "consumers"],
          "properties": {
            "owner": { "type": "string", "pattern": "^(backend|frontend)\\.[a-z0-9_]+$" },
            "location": { "type": "string" },
            "consumers": {
              "type": "array",
              "items": { "type": "string", "enum": ["backend", "frontend", "frontend-rsc", "frontend-client"] },
              "minItems": 1
            },
            "description": { "type": "string" }
          }
        }
      }
    }
  }
}
