{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VINTRACK Dependency Graph",
  "description": "Deterministic orchestration graph for milestones and tickets.",
  "type": "object",
  "required": ["milestones", "tickets"],
  "properties": {
    "milestones": {
      "type": "object",
      "patternProperties": {
        "^M[0-9]+$": {
          "type": "object",
          "required": ["depends_on", "surface"],
          "properties": {
            "depends_on": { "type": "array", "items": { "type": "string", "pattern": "^M[0-9]+$" } },
            "surface": { "type": "string", "enum": ["backend", "frontend-rsc", "frontend-client", "shared", "infrastructure", "fullstack", "ci-cd"] }
          }
        }
      }
    },
    "tickets": {
      "type": "object",
      "patternProperties": {
        "^T[0-9]+\\.[0-9A-Z]+$": {
          "type": "object",
          "required": ["depends_on", "surface"],
          "properties": {
            "depends_on": {
              "type": "array",
              "items": {
                "type": "string",
                "anyOf": [
                  { "pattern": "^M[0-9]+$" },
                  { "pattern": "^T[0-9]+\\.[0-9A-Z]+$" }
                ]
              }
            },
            "surface": { "type": "string", "enum": ["backend", "frontend-rsc", "frontend-client", "shared", "infrastructure", "fullstack", "ci-cd"] }
          }
        }
      }
    }
  }
}
