{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/dependency-graph",
  "title": "DependencyGraph",
  "type": "object",
  "required": ["version", "generated_at", "milestone_dependencies", "domain_events", "database", "queues", "services", "infrastructure"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "generated_at": { "type": "string", "format": "date-time" },
    "milestone_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "depends_on", "critical_path"],
        "properties": {
          "id": { "type": "string", "pattern": "^M[0-9]+$" },
          "title": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string", "pattern": "^M[0-9]+$" } },
          "blocks": { "type": "array", "items": { "type": "string", "pattern": "^M[0-9]+$" } },
          "critical_path": { "type": "boolean" },
          "parallelizable": { "type": "boolean" }
        }
      }
    },
    "domain_events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["consumer_domain", "events", "producer_domain"],
        "properties": {
          "consumer_domain": { "type": "string" },
          "producer_domain": { "type": "string" },
          "events": { "type": "array", "items": { "type": "string" } },
          "required": { "type": "boolean" }
        }
      }
    },
    "database": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["table", "owned_by"],
        "properties": {
          "table": { "type": "string" },
          "owned_by": { "type": "string" },
          "referenced_by": { "type": "array", "items": { "type": "string" } },
          "mutation_rule": { "type": "string", "enum": ["owner_only", "read_only_projection"] }
        }
      }
    },
    "queues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "producer", "consumer"],
        "properties": {
          "name": { "type": "string" },
          "producer": { "type": "string" },
          "consumer": { "type": "string" },
          "blocks_if_down": { "type": "string" },
          "critical": { "type": "boolean" }
        }
      }
    },
    "services": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "depends_on"],
        "properties": {
          "name": { "type": "string" },
          "depends_on": { "type": "array", "items": { "type": "string" } },
          "critical_path": { "type": "boolean" }
        }
      }
    },
    "infrastructure": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component", "required_by"],
        "properties": {
          "component": { "type": "string" },
          "required_by": { "type": "array", "items": { "type": "string" } },
          "fallback": { "type": "string" },
          "hard_dependency": { "type": "boolean" }
        }
      }
    },
    "circular_dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["potential_cycle", "resolution"],
        "properties": {
          "potential_cycle": { "type": "string" },
          "resolution": { "type": "string" }
        }
      }
    },
    "impact_analysis": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["component", "impact"],
        "properties": {
          "component": { "type": "string" },
          "impact": { "type": "string" },
          "severity": { "type": "string", "enum": ["platform_halt", "commerce_halt", "degraded", "none"] }
        }
      }
    }
  }
}
