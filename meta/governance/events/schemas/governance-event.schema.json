{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/governance-event.schema.json",
  "title": "VINTRACK Governance Event",
  "description": "Canonical schema for governance runtime events. All major runtime actions emit events conforming to this structure.",
  "type": "object",
  "required": ["event_id", "timestamp", "event_type", "severity", "category"],
  "properties": {
    "event_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique event identifier"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO-8601 event timestamp"
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z]+\\.[a-z]+(_[a-z]+)*$",
      "description": "Namespaced event type, e.g. execution.started"
    },
    "severity": {
      "type": "string",
      "enum": ["debug", "info", "warn", "error", "critical"],
      "description": "Event severity level"
    },
    "category": {
      "type": "string",
      "enum": ["execution", "validation", "recovery", "governance", "runtime", "planning", "diagnostics"],
      "description": "Event category for filtering and routing"
    },
    "execution_id": {
      "type": ["string", "null"],
      "pattern": "^EXEC-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$",
      "description": "Associated execution ID"
    },
    "milestone": {
      "type": ["string", "null"],
      "pattern": "^M[0-9]+$"
    },
    "ticket": {
      "type": ["string", "null"],
      "pattern": "^T[0-9]+\\.[0-9A-Z]+$"
    },
    "actor": {
      "type": "string",
      "enum": ["agent", "human", "system", "scheduler"],
      "description": "Who or what triggered the event"
    },
    "session_id": {
      "type": ["string", "null"],
      "description": "Agent session identifier"
    },
    "correlation_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Traces distributed workflow"
    },
    "causation_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Event that caused this event"
    },
    "global_sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing sequence across all events"
    },
    "execution_sequence": {
      "type": "integer",
      "minimum": 1,
      "description": "Monotonically increasing sequence within an execution"
    },
    "parent_event_id": {
      "type": ["string", "null"],
      "format": "uuid",
      "description": "Causally preceding event in the same execution"
    },
    "causality_chain": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" },
      "description": "Ordered chain of ancestor event IDs within this execution"
    },
    "payload": {
      "type": "object",
      "description": "Event-specific data"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "source_file": { "type": "string" },
        "line_number": { "type": "integer" },
        "git_commit": { "type": "string" },
        "version": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
