{
  "protocol_version": "1.0.0",
  "policy_id": "control-plane-operations",
  "authority": "meta/governance/protocols/control-plane-policy.json",
  "description": "Operational policy governing control plane actions, intent emission, approval chains, and execution orchestration",
  "principles": [
    "Intent emission precedes execution",
    "Every action emits a governed event",
    "Destructive actions require human approval",
    "Rollback must be replay-safe",
    "Operator attribution is preserved in all action events"
  ],
  "approval_matrix": {
    "auto_approved": [
      "diagnostics_health_check",
      "enforcement_validate_all"
    ],
    "human_approval_required": [
      "healing_sync_projections",
      "orchestration_milestone_close",
      "self_heal_run",
      "state_transition"
    ],
    "governance_approval_required": [
      "policy_update",
      "invariant_bypass",
      "protocol_amendment"
    ]
  },
  "event_families": {
    "control.action.requested": {
      "description": "Operator intent emitted",
      "severity": "info",
      "required_fields": ["action_id", "actor", "intent"],
      "emitted_by": ["dashboard", "cli", "api", "agent"]
    },
    "control.action.approved": {
      "description": "Human or governance authorization granted",
      "severity": "info",
      "required_fields": ["action_id", "approved_by", "approved_at"],
      "emitted_by": ["approval_layer"]
    },
    "control.action.rejected": {
      "description": "Action denied by invariant or human",
      "severity": "warn",
      "required_fields": ["action_id", "rejected_by", "rejection_reason"],
      "emitted_by": ["approval_layer", "guard_layer"]
    },
    "control.action.executed": {
      "description": "Action successfully executed",
      "severity": "info",
      "required_fields": ["action_id", "result"],
      "emitted_by": ["orchestration_layer"]
    },
    "control.action.failed": {
      "description": "Action execution failed",
      "severity": "error",
      "required_fields": ["action_id", "error"],
      "emitted_by": ["orchestration_layer"]
    },
    "control.action.rolled_back": {
      "description": "Rollback executed after failure",
      "severity": "warn",
      "required_fields": ["action_id", "rollback_reason"],
      "emitted_by": ["orchestration_layer"]
    },
    "control.suggestion.generated": {
      "description": "Non-mutating recommendation produced",
      "severity": "debug",
      "required_fields": ["suggestion_id", "actor", "recommendation"],
      "emitted_by": ["suggestion_engine"]
    },
    "control.recipe.invoked": {
      "description": "Recipe execution initiated",
      "severity": "info",
      "required_fields": ["recipe_id", "action_id", "actor"],
      "emitted_by": ["orchestration_layer"]
    },
    "control.guard.blocked": {
      "description": "Invariant guard prevented action",
      "severity": "warn",
      "required_fields": ["action_id", "invariant", "guard_behavior"],
      "emitted_by": ["guard_layer"]
    }
  },
  "execution_model": {
    "intent_emission": {
      "description": "Surface emits intent event",
      "next_stage": "validation"
    },
    "validation": {
      "description": "Guard layer validates against invariants and policy",
      "next_stage_approved": "approval",
      "next_stage_rejected": "rejection"
    },
    "approval": {
      "description": "Approval layer checks human/governance authorization",
      "next_stage_approved": "execution",
      "next_stage_rejected": "rejection"
    },
    "execution": {
      "description": "Orchestration layer executes recipe steps",
      "next_stage_success": "completion",
      "next_stage_failure": "rollback"
    },
    "rollback": {
      "description": "Rollback steps executed to reverse mutation",
      "next_stage": "failure_report"
    },
    "rejection": {
      "description": "Action denied, no mutation occurs",
      "final": true
    },
    "completion": {
      "description": "Action completed successfully",
      "final": true
    },
    "failure_report": {
      "description": "Failure and rollback documented",
      "final": true
    }
  },
  "metadata": {
    "created_at": "2026-05-25T02:30:00Z",
    "updated_at": "2026-05-25T02:30:00Z",
    "version": 1
  }
}
