{
  "$schema": "./schema/recipe.schema.json",
  "id": "recover-from-failure",
  "version": "1.0.0",
  "category": "recovery",
  "title": "Recover from Execution Failure",
  "purpose": "Systematically diagnose and recover from a failed execution using replay, telemetry analysis, and rollback.",
  "prerequisites": [
    "Failed execution_id is known",
    "Event streams contain failure data",
    "Replay system is operational"
  ],
  "steps": [
    {
      "id": "replay-failure",
      "description": "Replay the failed execution to reconstruct timeline",
      "command": "tsx scripts/replay-execution.ts <execution_id>",
      "validation": "Manifest and timeline generated"
    },
    {
      "id": "analyze-timeline",
      "description": "Review timeline report for error patterns",
      "validation": "Root cause hypothesis documented"
    },
    {
      "id": "apply-fix",
      "description": "Apply corrective action based on analysis",
      "validation": "Fix committed with descriptive message"
    },
    {
      "id": "validate-recovery",
      "description": "Re-run validation to confirm fix",
      "command": "npm run pm:validate",
      "validation": "Exit code 0"
    }
  ],
  "recovery": {
    "auto_recoverable": false,
    "steps": [
      "Escalate to human operator",
      "Document failure in incident log"
    ]
  },
  "rollback": {
    "required": false,
    "snapshot_before": false,
    "steps": []
  },
  "validation": [
    "Replay shows complete reconstruction",
    "Timeline identifies root cause",
    "npm run pm:validate passes after fix"
  ],
  "estimated_duration_minutes": 30,
  "risk_level": "high"
}
