{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/protocol-definition.schema.json",
  "title": "VINTRACK Protocol Definition",
  "description": "Canonical schema for machine-readable governance protocol definitions. Markdown protocols are generated reflections of JSON definitions using this schema.",
  "type": "object",
  "required": ["id", "version", "layer", "scope", "derives_from", "canonical"],
  "properties": {
    "$schema": { "type": "string", "description": "Self-referencing JSON Schema URI" },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]+$",
      "description": "URL-safe protocol identifier"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "title": {
      "type": "string",
      "description": "Human-readable protocol title"
    },
    "description": {
      "type": "string",
      "description": "Detailed protocol description"
    },
    "layer": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5,
      "description": "Authority hierarchy layer"
    },
    "scope": {
      "type": "string",
      "enum": ["execution", "behavior", "state", "recovery", "authorization", "planning", "governance"]
    },
    "canonical": {
      "type": "boolean",
      "description": "Whether this is the current authority for its scope"
    },
    "status": {
      "type": "string",
      "enum": ["active", "deprecated", "draft", "superseded"],
      "default": "active"
    },
    "derives_from": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Higher-layer document IDs this extends"
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Protocol IDs this one replaces"
    },
    "narrative_ref": {
      "type": "string",
      "description": "Path to narrative content file (relative to meta/governance/narratives/)"
    },
    "purpose": {
      "type": "string",
      "description": "One-line purpose statement"
    },
    "state_machine": {
      "type": "object",
      "description": "Optional state machine definition",
      "properties": {
        "states": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "terminal": { "type": "boolean", "default": false },
              "entry_trigger": { "type": "string" },
              "exit_trigger": { "type": "string" },
              "semantics": { "type": "string" }
            }
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "trigger"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "trigger": { "type": "string" },
              "guard": { "type": ["string", "null"] },
              "description": { "type": "string" }
            }
          }
        },
        "forbidden_transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "reason"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "reason": { "type": "string" }
            }
          }
        }
      }
    },
    "rules": {
      "type": "array",
      "description": "Conditional rule definitions",
      "items": {
        "type": "object",
        "required": ["id", "condition", "action"],
        "properties": {
          "id": { "type": "string" },
          "condition": { "type": "string" },
          "action": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
          },
          "description": { "type": "string" }
        }
      }
    },
    "invariants": {
      "type": "array",
      "description": "Must-always-be-true predicates",
      "items": {
        "type": "object",
        "required": ["id", "expression"],
        "properties": {
          "id": { "type": "string" },
          "expression": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
          },
          "description": { "type": "string" }
        }
      }
    },
    "triggers": {
      "type": "array",
      "description": "Event or condition triggers",
      "items": {
        "type": "object",
        "required": ["id", "category"],
        "properties": {
          "id": { "type": "string" },
          "category": {
            "type": "string",
            "enum": ["mandatory", "optional", "throttled"]
          },
          "condition": { "type": "string" },
          "throttle": {
            "type": "object",
            "properties": {
              "max_per_minute": { "type": "integer" },
              "cooldown_seconds": { "type": "integer" }
            }
          },
          "description": { "type": "string" }
        }
      }
    },
    "intent_classifications": {
      "type": "array",
      "description": "Intent classification categories",
      "items": {
        "type": "object",
        "required": ["category", "behavior"],
        "properties": {
          "category": { "type": "string" },
          "behavior": { "type": "string", "enum": ["EXECUTIONAL", "NON_EXECUTIONAL"] },
          "examples": {
            "type": "array",
            "items": { "type": "string" }
          },
          "description": { "type": "string" }
        }
      }
    },
    "emissions": {
      "type": "object",
      "description": "Event emission mappings for state machine protocols",
      "additionalProperties": { "type": "string" }
    },
    "schemas": {
      "type": "object",
      "description": "Named payload schemas referenced by this protocol",
      "additionalProperties": {
        "type": "object",
        "description": "JSON Schema object"
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "author": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
