{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/execution-freeze.schema.json",
  "title": "VINTRACK Execution Freeze",
  "description": "Schema for execution freeze state and guarantee declarations.",
  "type": "object",
  "required": ["freeze_state", "incident_id", "guarantees"],
  "properties": {
    "freeze_state": {
      "type": "string",
      "enum": ["UNFROZEN", "FREEZE_INITIATED", "FROZEN", "THAW_INITIATED", "THAWED"]
    },
    "incident_id": { "type": "string" },
    "initiated_at": { "type": "string", "format": "date-time" },
    "confirmed_at": { "type": "string", "format": "date-time" },
    "thaw_initiated_at": { "type": "string", "format": "date-time" },
    "thawed_at": { "type": "string", "format": "date-time" },
    "guarantees": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "active"],
        "properties": {
          "id": { "type": "string" },
          "active": { "type": "boolean" },
          "verified_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
