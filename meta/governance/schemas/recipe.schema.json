{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/recipe",
  "title": "Governance Recipe",
  "description": "Canonical executable operational intent for the governance runtime",
  "type": "object",
  "required": [
    "id",
    "version",
    "category",
    "description",
    "capabilities",
    "determinism",
    "inputs",
    "guards",
    "steps",
    "emits",
    "rollback",
    "requiresApproval",
    "replaySafe",
    "compatibility"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z]+_[a-z_]+$",
      "description": "Unique recipe identifier, e.g. heal_projection_drift"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version"
    },
    "category": {
      "type": "string",
      "enum": ["enforcement", "healing", "diagnostics", "orchestration", "migration"],
      "description": "Recipe classification"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Human-readable purpose"
    },
    "capabilities": {
      "type": "array",
      "description": "Capability classes this recipe exercises",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["read", "emit", "mutate", "destructive", "orchestration", "recovery"]
      }
    },
    "determinism": {
      "type": "object",
      "required": ["deterministic", "idempotent", "replaySafe"],
      "properties": {
        "deterministic": {
          "type": "boolean",
          "description": "Same inputs always produce same behavior"
        },
        "idempotent": {
          "type": "boolean",
          "description": "Safe to execute multiple times"
        },
        "replaySafe": {
          "type": "boolean",
          "description": "Valid during replay reconstruction"
        },
        "sideEffects": {
          "type": "array",
          "items": { "type": "string" },
          "description": "External mutation surfaces touched"
        }
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "required"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string" },
          "required": { "type": "boolean" },
          "default": {},
          "description": { "type": "string" }
        }
      }
    },
    "guards": {
      "type": "array",
      "description": "Invariant gates that must pass before execution",
      "items": {
        "type": "object",
        "required": ["invariant", "behavior"],
        "properties": {
          "invariant": { "type": "string" },
          "behavior": {
            "type": "string",
            "enum": ["block", "warn", "skip"]
          },
          "description": { "type": "string" }
        }
      }
    },
    "steps": {
      "type": "array",
      "description": "Ordered execution steps",
      "items": {
        "type": "object",
        "required": ["order", "action", "command"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "action": { "type": "string" },
          "command": { "type": "string" },
          "description": { "type": "string" },
          "timeout_seconds": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "emits": {
      "type": "array",
      "description": "Governance events emitted during execution",
      "items": {
        "type": "object",
        "required": ["event_type", "severity", "category"],
        "properties": {
          "event_type": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["debug", "info", "warn", "error", "critical"]
          },
          "category": {
            "type": "string",
            "enum": ["execution", "validation", "recovery", "governance", "runtime", "planning", "diagnostics"]
          },
          "payload_schema": { "type": "string" }
        }
      }
    },
    "rollback": {
      "type": "array",
      "description": "Steps to reverse mutation if execution fails",
      "items": {
        "type": "object",
        "required": ["order", "action", "command"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "action": { "type": "string" },
          "command": { "type": "string" },
          "description": { "type": "string" }
        }
      }
    },
    "requiresApproval": {
      "type": "boolean",
      "description": "Whether human approval is required before execution"
    },
    "actionClass": {
      "type": "string",
      "enum": ["observational", "administrative", "enforcement", "recovery", "destructive", "orchestration"],
      "description": "Operational classification for approval routing and risk assessment"
    },
    "compatibility": {
      "type": "object",
      "required": ["minimumRuntime"],
      "properties": {
        "minimumRuntime": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "description": "Minimum governance runtime version"
        },
        "deprecated": {
          "type": "boolean",
          "description": "Whether this recipe version is deprecated"
        },
        "supersededBy": {
          "type": "string",
          "description": "Recipe ID that supersedes this one"
        }
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Recipe dependency graph",
      "properties": {
        "invokes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recipes this recipe directly invokes"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recipes that must execute before this one"
        },
        "blocks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recipes that cannot execute while this one is active"
        },
        "supersedes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Recipe versions this one replaces"
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "author": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
