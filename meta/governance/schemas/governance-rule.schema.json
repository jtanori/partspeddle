{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/governance-rule.schema.json",
  "title": "VINTRACK Governance Rule",
  "description": "Schema for enforceable governance rules derived from protocols.",
  "type": "object",
  "required": ["rule_id", "protocol_id", "condition", "action", "severity"],
  "properties": {
    "rule_id": { "type": "string", "pattern": "^[a-z][a-z0-9-_.]+$" },
    "protocol_id": { "type": "string" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "condition": { "type": "string", "description": "Predicate expression triggering the rule" },
    "action": { "type": "string", "description": "Action to take when condition is met" },
    "severity": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
    "enforcement": {
      "type": "string",
      "enum": ["block", "warn", "log", "escalate"],
      "description": "How the rule is enforced at runtime"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  },
  "additionalProperties": false
}
