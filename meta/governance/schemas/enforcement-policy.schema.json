{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/enforcement-policy.schema.json",
  "title": "VINTRACK Enforcement Policy",
  "description": "Schema for how governance rules are enforced at runtime.",
  "type": "object",
  "required": ["policy_id", "version", "rules"],
  "properties": {
    "policy_id": { "type": "string", "pattern": "^[a-z][a-z0-9-_.]+$" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "default_action": { "type": "string", "enum": ["block", "warn", "log", "escalate"] },
    "rules": {
      "type": "array",
      "items": { "$ref": "governance-rule.schema.json" }
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "rule_id": { "type": "string" },
          "exception_condition": { "type": "string" },
          "authorized_by": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
