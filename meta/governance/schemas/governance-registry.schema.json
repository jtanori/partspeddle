{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/governance-registry.schema.json",
  "title": "VINTRACK Governance Registry",
  "description": "Canonical registry for all machine-readable governance definitions.",
  "type": "object",
  "required": ["version", "protocols", "schemas", "rules", "reflections"],
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "protocols": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "version", "scope", "canonical"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "version": { "type": "string" },
          "scope": { "type": "string" },
          "canonical": { "type": "boolean" },
          "layer": { "type": "integer", "minimum": 0, "maximum": 5 },
          "authority": { "type": "string", "description": "Absolute or relative path to the canonical JSON definition" },
          "dependencies": { "type": "array", "items": { "type": "string" }, "description": "Protocol IDs this extends (derives_from)" },
          "superseded_by": { "type": ["string", "null"], "description": "Protocol ID that supersedes this one, if any" },
          "lifecycle_status": { "type": "string", "enum": ["active", "deprecated", "draft", "superseded"] },
          "supersedes": { "type": "array", "items": { "type": "string" } },
          "reflection_path": { "type": ["string", "null"] },
          "validator_path": { "type": ["string", "null"] }
        }
      }
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "version"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "version": { "type": "string" },
          "$id": { "type": "string", "description": "Schema URI identifier" },
          "authority": { "type": "string", "description": "Path to schema definition" },
          "compatibility_version": { "type": "string", "description": "Minimum compatible registry version" }
        }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "protocol_id"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "protocol_id": { "type": "string" }
        }
      }
    },
    "reflections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "source_protocol", "generated_path"],
        "properties": {
          "id": { "type": "string" },
          "source_protocol": { "type": "string" },
          "generated_path": { "type": "string" },
          "last_generated_at": { "type": "string", "format": "date-time" }
        }
      }
    },
    "events": {
      "type": "object",
      "required": ["schema", "catalog", "policy", "emitter", "query", "validator", "streams_dir"],
      "properties": {
        "schema": { "type": "string" },
        "catalog": { "type": "string" },
        "policy": { "type": "string" },
        "emitter": { "type": "string" },
        "query": { "type": "string" },
        "validator": { "type": "string" },
        "streams_dir": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
