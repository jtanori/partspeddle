{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/dashboard",
  "title": "Governance Dashboard Surface Contract",
  "description": "Operational surface contract for every dashboard component. Defines authority, mutability, freshness, replay visibility, approval gating, and risk classification.",
  "type": "object",
  "required": ["surfaces"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "description",
          "authority",
          "mutability",
          "freshness",
          "replayVisibility",
          "approvalRequired",
          "riskLevel",
          "dataSources"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z]+(_[a-z]+)*$"
          },
          "name": { "type": "string" },
          "description": { "type": "string", "minLength": 10 },
          "authority": {
            "type": "string",
            "enum": ["canonical", "projected", "derived", "topology"],
            "description": "Source of truth layer for this surface"
          },
          "mutability": {
            "type": "string",
            "enum": ["read-only", "actionable"],
            "description": "Whether this surface can trigger mutations"
          },
          "freshness": {
            "type": "string",
            "enum": ["realtime", "near-realtime", "delayed"],
            "description": "Data freshness requirement"
          },
          "freshness_seconds": {
            "type": "integer",
            "minimum": 0,
            "description": "Maximum acceptable staleness in seconds"
          },
          "replayVisibility": {
            "type": "boolean",
            "description": "Whether actions on this surface emit replay-addressable events"
          },
          "approvalRequired": {
            "type": "boolean",
            "description": "Whether operator approval is required for actionable surfaces"
          },
          "riskLevel": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "description": "Operational severity of misusing this surface"
          },
          "dataSources": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source", "path"],
              "properties": {
                "source": {
                  "type": "string",
                  "enum": ["canonical-state", "projection", "event-stream", "topology", "recipe-registry", "checkpoint", "bootstrap"]
                },
                "path": { "type": "string" },
                "query": { "type": "string" }
              }
            }
          },
          "queryPattern": {
            "type": "string",
            "description": "How the dashboard fetches data for this surface"
          },
          "recipeIds": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Associated recipes for actionable surfaces"
          },
          "events": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["event_type", "emitted_on"],
              "properties": {
                "event_type": { "type": "string" },
                "emitted_on": { "type": "string", "enum": ["view", "action", "refresh", "error"] }
              }
            }
          },
          "filters": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["field", "type"],
              "properties": {
                "field": { "type": "string" },
                "type": { "type": "string" },
                "required": { "type": "boolean" }
              }
            }
          },
          "metadata": {
            "type": "object"
          }
        }
      }
    }
  }
}
