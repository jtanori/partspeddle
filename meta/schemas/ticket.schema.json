{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://vintrack.io/schemas/ticket.schema.json",
  "title": "VINTRACK Ticket",
  "description": "Canonical schema for ticket definitions",
  "type": "object",
  "required": ["id", "milestone_id", "title", "domain", "capability", "purpose", "dependencies", "deliverables", "acceptance_criteria", "estimated_hours", "status"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^T[0-9]+\\.[0-9A-Z]+$",
      "description": "Ticket identifier"
    },
    "milestone_id": {
      "type": "string",
      "pattern": "^M[0-9]+(\\.[0-9]+)?$",
      "description": "Parent milestone identifier"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable ticket title"
    },
    "domain": {
      "type": "string",
      "enum": ["Shared", "Identity", "Marketplace", "Transactions", "Messaging", "Search", "AI", "Infrastructure"],
      "description": "Bounded context domain"
    },
    "capability": {
      "type": "string",
      "minLength": 1,
      "description": "Capability area this ticket addresses"
    },
    "purpose": {
      "type": "string",
      "minLength": 1,
      "description": "Why this ticket exists"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^T[0-9]+(\\.[0-9A-Z]+)+$"
      },
      "description": "Tickets that must complete before this one"
    },
    "architectural_constraints": {
      "type": "array",
      "items": { "type": "string" },
      "description": "In-force constraints for this ticket"
    },
    "deliverables": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "description", "type"],
        "properties": {
          "path": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "enum": ["file", "directory", "schema", "code", "config"] }
        }
      },
      "minItems": 1,
      "description": "Expected outputs"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "description": "Validation criteria for completion"
    },
    "estimated_hours": {
      "type": "number",
      "minimum": 0,
      "description": "Estimated hours to complete"
    },
    "status": {
      "type": "string",
      "enum": ["planned", "in_progress", "review", "completed", "blocked", "cancelled"],
      "description": "Current ticket status"
    },
    "traceability": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "commit_hash": { "type": "string" },
          "files_changed": { "type": "array", "items": { "type": "string" } },
          "description": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Execution traceability log"
    },
    "metadata": {
      "type": "object",
      "description": "Optional ticket metadata"
    }
  }
}
