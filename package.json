{
  "name": "vintrack",
  "version": "0.1.0",
  "description": "Trust-centric collectible asset transaction platform",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src/ tests/ --ext .ts",
    "lint:fix": "eslint src/ tests/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "tsx scripts/seed.ts",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "security:scan": "npx secretlint \"**/*\"",
    "pm:validate": "node scripts/validate-pm.js",
    "pm:status": "node scripts/pm-status.js",
    "pm:report": "node scripts/pm-report.js",
    "pm:report:json": "node scripts/pm-report.js --json",
    "pm:assess": "node scripts/pm-assess.js",
    "pm:summary": "node scripts/pm-summary.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.49.4",
    "bullmq": "5.49.1",
    "express": "4.21.2",
    "ioredis": "5.6.1",
    "postgres": "3.4.5",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@types/express": "5.0.1",
    "@types/node": "22.15.18",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "eslint": "9.26.0",
    "eslint-config-prettier": "10.1.5",
    "prettier": "3.5.3",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
