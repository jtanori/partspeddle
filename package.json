{
  "name": "vintrack",
  "version": "0.1.0",
  "description": "Trust-centric collectible asset transaction platform",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "PORT=3001 tsx watch src/app.ts",
    "dev:frontend": "next dev -p 3000",
    "build": "tsc",
    "build:frontend": "next build",
    "start": "node dist/app.js",
    "test": "./node_modules/.bin/vitest",
    "test:unit": "./node_modules/.bin/vitest run --config vitest.unit.config.ts",
    "test:integration": "./node_modules/.bin/vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:ci": "./node_modules/.bin/vitest run --coverage",
    "lint": "eslint src/ tests/ --ext .ts,.tsx",
    "lint:frontend": "eslint src/frontend/ src/app/ --ext .ts,.tsx",
    "lint:fix": "eslint src/ tests/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"src/**/*.tsx\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"src/**/*.tsx\" \"tests/**/*.ts\"",
    "typecheck:frontend": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "tsx scripts/seed.ts",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "security:scan": "npx secretlint \"**/*\"",
    "pm:validate": "node scripts/validate-pm.js",
    "pm:status": "node scripts/pm-status.js",
    "pm:report": "node scripts/pm-report.js",
    "pm:report:json": "node scripts/pm-report.js --json",
    "pm:assess": "node scripts/pm-assess.js",
    "pm:summary": "node scripts/pm-summary.js",
    "governance:validate": "./node_modules/.bin/tsx scripts/generate-governance.ts --validate-only",
    "governance:generate": "./node_modules/.bin/tsx scripts/generate-governance.ts",
    "governance:diff": "git diff --exit-code project-governance/protocols/*.protocol.md scripts/validators/protocol-*.ts",
    "governance:event:emit": "./node_modules/.bin/tsx scripts/emit-governance-event.ts",
    "governance:event:query": "./node_modules/.bin/tsx scripts/query-governance-events.ts",
    "governance:event:validate": "./node_modules/.bin/tsx meta/governance/tests/run-governance-event-tests.ts",
    "telemetry:emit": "./node_modules/.bin/tsx scripts/emit-telemetry.ts",
    "telemetry:validate": "./node_modules/.bin/tsx scripts/validate-telemetry.ts",
    "telemetry:test": "./node_modules/.bin/tsx project-governance/runtime/telemetry/tests/run-telemetry-tests.ts",
    "replay:run": "./node_modules/.bin/tsx scripts/replay-execution.ts",
    "replay:test": "./node_modules/.bin/tsx project-governance/runtime/replay/tests/run-replay-tests.ts",
    "diagnostics:run": "./node_modules/.bin/tsx scripts/diagnostics-console.ts",
    "diagnostics:health": "./node_modules/.bin/tsx scripts/diagnostics-console.ts --quick",
    "diagnostics:test": "./node_modules/.bin/tsx project-governance/runtime/diagnostics/tests/run-diagnostics-tests.ts",
    "suggestions:generate": "./node_modules/.bin/tsx scripts/suggest-next-actions.ts",
    "suggestions:test": "./node_modules/.bin/tsx project-governance/intelligence/suggestions/tests/run-suggestion-tests.ts",
    "recipe:execute": "./node_modules/.bin/tsx scripts/execute-recipe.ts",
    "recipe:generate-md": "./node_modules/.bin/tsx scripts/generate-recipe-md.ts",
    "recipe:test": "./node_modules/.bin/tsx project-governance/recipes/tests/run-recipe-tests.ts",
    "patterns:analyze": "./node_modules/.bin/tsx scripts/analyze-workflow-patterns.ts",
    "patterns:test": "./node_modules/.bin/tsx project-governance/intelligence/pattern-reports/tests/run-pattern-tests.ts",
    "state:transition": "./node_modules/.bin/tsx scripts/execution-state.ts transition",
    "state:current": "./node_modules/.bin/tsx scripts/execution-state.ts current",
    "state:history": "./node_modules/.bin/tsx scripts/execution-state.ts history",
    "state:reset": "./node_modules/.bin/tsx scripts/execution-state.ts reset",
    "state:test": "./node_modules/.bin/tsx project-governance/runtime/state-machine/tests/run-state-machine-tests.ts",
    "lock:acquire": "./node_modules/.bin/tsx scripts/execution-lock.ts acquire",
    "lock:release": "./node_modules/.bin/tsx scripts/execution-lock.ts release",
    "lock:state": "./node_modules/.bin/tsx scripts/execution-lock.ts state",
    "lock:detect-stale": "./node_modules/.bin/tsx scripts/detect-stale-locks.ts",
    "lock:test": "./node_modules/.bin/tsx project-governance/runtime/locks/tests/run-lock-tests.ts",
    "enforce:check": "./node_modules/.bin/tsx scripts/enforce-governance.ts check",
    "enforce:run": "./node_modules/.bin/tsx scripts/enforce-governance.ts enforce",
    "enforce:transition": "./node_modules/.bin/tsx scripts/enforce-governance.ts transition",
    "enforce:test": "./node_modules/.bin/tsx project-governance/runtime/enforcement/tests/run-enforcement-tests.ts",
    "heal:scan": "./node_modules/.bin/tsx scripts/self-heal.ts scan",
    "heal:run": "./node_modules/.bin/tsx scripts/self-heal.ts heal",
    "heal:snapshot": "./node_modules/.bin/tsx scripts/self-heal.ts snapshot",
    "heal:test": "./node_modules/.bin/tsx project-governance/runtime/healing/tests/run-healing-tests.ts",
    "audit:run": "./node_modules/.bin/tsx scripts/audit-runtime.ts run",
    "audit:json": "./node_modules/.bin/tsx scripts/audit-runtime.ts json",
    "audit:list": "./node_modules/.bin/tsx scripts/audit-runtime.ts list",
    "audit:test": "./node_modules/.bin/tsx project-governance/runtime/audits/tests/run-audit-tests.ts",
    "resolve:continuation": "tsx scripts/resolve-continuation.ts",
    "resolve:continuation:json": "tsx scripts/resolve-continuation.ts --json",
    "tool:status": "tools/runtime/status.sh",
    "tool:lock": "tools/runtime/lock-status.sh",
    "tool:checkpoints": "tools/runtime/checkpoint-list.sh",
    "tool:continuation": "tools/governance/continuation-resolve.sh",
    "tool:progress": "tools/governance/milestone-progress.sh",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "invariant:validate": "./node_modules/.bin/tsx scripts/validate-invariants.ts",
    "invariant:validate:json": "./node_modules/.bin/tsx scripts/validate-invariants.ts --json",
    "invariant:monitor": "./node_modules/.bin/tsx scripts/invariant-monitor.ts daemon",
    "invariant:monitor:once": "./node_modules/.bin/tsx scripts/invariant-monitor.ts once",
    "storage:health": "./node_modules/.bin/tsx scripts/runtime-storage.ts health",
    "storage:read": "./node_modules/.bin/tsx scripts/runtime-storage.ts read",
    "storage:list": "./node_modules/.bin/tsx scripts/runtime-storage.ts list",
    "storage:migrate-plan": "./node_modules/.bin/tsx scripts/runtime-storage.ts migrate-plan",
    "storage:validate": "./node_modules/.bin/tsx scripts/runtime-storage.ts health && npm run invariant:validate",
    "storage:test": "./node_modules/.bin/tsx project-governance/runtime/storage/tests/run-storage-tests.ts",
    "storage:migrate-check": "./node_modules/.bin/tsx scripts/migrate-to-storage-adapter.ts",
    "projection:sync": "./node_modules/.bin/tsx scripts/sync-projections.ts",
    "projection:validate": "./node_modules/.bin/tsx scripts/validate-projections.ts",
    "bootstrap:validate": "./node_modules/.bin/tsx scripts/validate-bootstrap.ts",
    "repository:sync": "./node_modules/.bin/tsx scripts/sync-repository-status.ts sync",
    "repository:validate": "./node_modules/.bin/tsx scripts/sync-repository-status.ts validate",
    "hygiene:validate": "./node_modules/.bin/tsx scripts/validate-repository-hygiene.ts",
    "causality:validate": "./node_modules/.bin/tsx scripts/validate-causality.ts",
    "replay:validate": "./node_modules/.bin/tsx scripts/validate-replay-integrity.ts",
    "benchmark:validate": "./node_modules/.bin/tsx scripts/validate-benchmark.ts",
    "topology:build": "./node_modules/.bin/tsx scripts/governance-topology.ts",
    "topology:visualize": "./node_modules/.bin/tsx scripts/governance-visualize.ts",
    "governance:query": "./node_modules/.bin/tsx scripts/governance-query.ts",
    "governance:impact": "./node_modules/.bin/tsx scripts/governance-impact.ts",
    "p0:validate": "npm run projection:sync && npm run repository:sync && npm run bootstrap && npm run invariant:validate && npm run storage:test && npm run projection:validate && npm run bootstrap:validate && npm run repository:validate && npm run hygiene:validate && npm run causality:validate && npm run replay:validate && npm run benchmark:validate"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "2.49.4",
    "@tailwindcss/postcss": "^4.3.0",
    "algoliasearch": "^5.52.1",
    "autoprefixer": "^10.5.0",
    "bullmq": "5.49.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "express": "4.21.2",
    "ioredis": "5.6.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "postcss": "^8.5.15",
    "postgres": "3.4.5",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-instantsearch": "^7.33.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "3.24.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "5.0.1",
    "@types/node": "22.15.18",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "8.32.0",
    "@typescript-eslint/parser": "8.32.0",
    "ajv-cli": "^5.0.0",
    "ajv-formats": "^3.0.1",
    "eslint": "9.26.0",
    "eslint-config-prettier": "10.1.5",
    "msw": "^2.14.6",
    "prettier": "3.5.3",
    "tsx": "4.19.4",
    "typescript": "5.8.3",
    "vitest": "3.2.4"
  }
}
